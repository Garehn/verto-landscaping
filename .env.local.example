# Lead form — emails each submission via Resend (resend.com).
#
# 1. Sign up free at https://resend.com (uses your email — no credit card)
# 2. From the dashboard, create an API key
# 3. Paste it here + on Vercel in Project Settings → Environment Variables
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where each lead should be delivered.
LEAD_TO_EMAIL=garehnn@gmail.com

# Optional. Defaults to "Verto Studio <onboarding@resend.dev>" which works
# without verifying a domain. Once you verify a domain on Resend, change this
# to e.g. "Verto Studio <studio@vertolandscaping.com>".
# LEAD_FROM_EMAIL=Verto Studio <studio@yourdomain.com>
